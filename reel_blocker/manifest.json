{
  "manifest_version": 3,
  "name": "FocusGuard: Reels Blocker",
  "version": "1.1.0",
  "description": "Enforces local focus policies with a UI toggle.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Settings"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}